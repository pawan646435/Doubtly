# /home/pawankumar/Desktop/Doubtly/backend/.env.example
# Doubtly Backend Environment Variables

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/doubtly
DB_FALLBACK_MODE=file
# Set DB_FALLBACK_MODE=disabled on Vercel and provide a real MongoDB URI.

# Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Kimi NVIDIA API Key
KIMI_API_KEY=your_kimi_api_key_here

# Server Port
PORT=5000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
